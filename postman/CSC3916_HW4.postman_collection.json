    {
      "name": "3 - Get All Movies (find a valid movieId)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "if (json.movies && json.movies.length > 0) {",
              "  pm.collectionVariables.set('movie_id', json.movies[0]._id);",
              "  pm.collectionVariables.set('movie_title', json.movies[0].title);",
              "  console.log('Saved movieId:', json.movies[0]._id);",
              "  console.log('Saved title:', json.movies[0].title);",
              "} else {",
              "  console.log('No movies found!');",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
